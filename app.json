{
  "expo": {
    "name": "Flipnova",
    "slug": "flipnova",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/flipnova_icon_1024.png",
    "scheme": "flipnova",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.suleymank.flipnova",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/flipnova_icon_1024.png",
        "backgroundColor": "#0f0c29"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/flipnova_splash.png",
          "imageWidth": 1284,
          "resizeMode": "cover",
          "backgroundColor": "#0f0c29",
          "dark": {
            "backgroundColor": "#0f0c29"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bb2608f4-4d5a-44b6-8112-595bc3858802"
      }
    }
  }
}